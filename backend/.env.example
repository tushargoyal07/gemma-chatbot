# 6-digit code users enter in the app UI. Default: 482913
# Change on Railway if you want a different shared code.
# ACCESS_CODE=482913

# Legacy API key (optional if ACCESS_CODE is set). Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
# API_KEY=

# Chat history — SQLite locally (default).
#
# Railway Postgres (recommended — do NOT paste the URL by hand):
#   1. Add a PostgreSQL plugin to the project.
#   2. On the backend service → Variables → "Add Reference" → Postgres → DATABASE_PRIVATE_URL
#      (preferred: internal network, no SSL issues) OR DATABASE_URL (public proxy).
#   3. Redeploy. Check GET /health/db after deploy.
#
# DATABASE_PRIVATE_URL is preferred when backend and Postgres run in the same Railway project.
# DATABASE_URL=sqlite+aiosqlite:///./data/chat.db

# LLM provider: groq (remote) | ollama (local / company GPU)
# LLM_PROVIDER=ollama

# --- Groq (remote, use for production now) ---

# GROQ_MODEL=llama-3.1-8b-instant
# GROQ_REQUEST_TIMEOUT=120

# --- Ollama (self-hosted Gemma 4 on company GPU later) ---
GEMMA_MODEL=gemma4:e2b
OLLAMA_BASE_URL=http://localhost:11434

# CORS — comma-separated frontend origins
CORS_ORIGINS=http://localhost:5173

# Optional regex for Vercel preview deploys (e.g. https://.*\.vercel\.app)
# CORS_ORIGIN_PATTERN=

# Environment: development | production
ENVIRONMENT=development

# Logging
LOG_LEVEL=INFO

# Server bind (Railway injects PORT automatically)
HOST=0.0.0.0
PORT=8000

# Ollama request settings
OLLAMA_REQUEST_TIMEOUT=120
OLLAMA_RETRY_ATTEMPTS=3
OLLAMA_RETRY_DELAY=1

# Fail startup if Ollama is unreachable (defaults to true in production)
STARTUP_VALIDATE_OLLAMA=false

# --- Production example (DigitalOcean / Railway + Groq) ---
# ENVIRONMENT=production
# ACCESS_CODE=482913
# LLM_PROVIDER=groq
# GROQ_API_KEY=gsk_...
# GROQ_MODEL=llama-3.1-8b-instant
# CORS_ORIGINS=https://chat.yourcompany.com

# --- Production example (company GPU Ollama on DigitalOcean) ---
# ENVIRONMENT=production
# ACCESS_CODE=482913
# LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://ollama:11434
# GEMMA_MODEL=gemma4:e2b
# CORS_ORIGINS=https://chat.yourcompany.com
