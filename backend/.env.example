# Model
GEMMA_MODEL=gemma4:e2b

# Ollama API base URL (local dev or public IP for production)
OLLAMA_BASE_URL=http://localhost:11434

# CORS — comma-separated frontend origins
CORS_ORIGINS=http://localhost:5173

# Optional regex for Vercel preview deploys (e.g. https://.*\.vercel\.app)
# CORS_ORIGIN_PATTERN=

# Environment: development | production
ENVIRONMENT=development

# Logging
LOG_LEVEL=INFO

# Server bind (Railway injects PORT automatically)
HOST=0.0.0.0
PORT=8000

# Ollama request settings
OLLAMA_REQUEST_TIMEOUT=120
OLLAMA_RETRY_ATTEMPTS=3
OLLAMA_RETRY_DELAY=1

# Fail startup if Ollama is unreachable (defaults to true in production)
STARTUP_VALIDATE_OLLAMA=false

# --- Production example (Railway) ---
# ENVIRONMENT=production
# OLLAMA_BASE_URL=http://<YOUR_PUBLIC_IP>:11434
# CORS_ORIGINS=https://your-app.vercel.app
# STARTUP_VALIDATE_OLLAMA=true
